{
  "exclude": ["lib", "**/fatal.js"],
  "references": [{ "path": "./tsconfig.build.json" }],
  "compilerOptions": {
    "checkJs": true,
    "exactOptionalPropertyTypes": true,
    "lib": ["es2022"],
    "module": "node16",
    "noEmit": true,
    "target": "es2022",
    "types": ["node"],
    "verbatimModuleSyntax": true
  }
}
